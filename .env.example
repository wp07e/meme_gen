# Copy to .env and fill in. All keys are required for full pipeline runs.
GIPHY_API_KEY=
KLIPY_API_KEY=
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2
# Local server
HOST=127.0.0.1
PORT=8000
# Storage directories (created on demand)
OUTPUT_DIR=output
TMP_DIR=tmp
UPLOADS_DIR=uploads
# --- Auth (login + admin). Set a strong SECRET_KEY before deploying. ---
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=
ADMIN_PASSWORD=
# --- Analytics (optional). Google Tag Manager container ID, e.g. GTM-XXXXXXX ---
GTM_CONTAINER_ID=
